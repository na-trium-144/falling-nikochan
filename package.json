{
  "name": "falling-nikochan",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": "^23.6 || ^24",
    "pnpm": ">=10.26.0"
  },
  "devEngines": {
    "runtime": [
      {
        "name": "node",
        "version": "^24",
        "onFail": "warn"
      }
    ],
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.26.0 <11",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "lint": "tsc && pnpm run -r --if-present t && pnpm run -r --if-present lint",
    "format": "prettier --write .",
    "t": "pnpm run -r --if-present t",
    "cdev": "pnpm run --filter chart cdev",
    "test": "pnpm run -r --if-present test",
    "mongo-docker": "docker run --rm -p 27017:27017 -d mongo:8.0.4",
    "seed": "pnpm run -r --if-present t && pnpm run --filter route seed",
    "ndev": "pnpm run --filter frontend dev",
    "nbuild": "pnpm run -r --if-present t && pnpm run --filter frontend build && pnpm run --filter frontend postbuild",
    "swbuild": "pnpm run -r --if-present t && pnpm run --filter worker build && pnpm run --filter frontend postbuild",
    "allbuild": "pnpm run -r --if-present t && pnpm run --filter frontend build && pnpm run --filter worker build && pnpm run --filter frontend postbuild",
    "ldev": "pnpm run --filter route dev"
  },
  "dependencies": {
    "@falling-nikochan/route": "workspace:*",
    "@sentry/hono": "catalog:",
    "@vercel/functions": "^3.6.2",
    "@vercel/og": "catalog:",
    "hono": "catalog:",
    "mongodb": "catalog:"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@eslint/config-helpers": "^0.4.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tsconfig/node23": "^23.0.4",
    "@types/node": "^22.19.7",
    "core-js": "3.49.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "next": "catalog:",
    "prettier": "^3.8.3",
    "semver": "^7.7.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-license-plugin": "^4.5.1"
  }
}
